{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
     "typeRoots": [
            "./node_modules/@types",
            "src/helper/types/env.d.ts"
        ]
  },
  "include": ["src/**/*.ts"]
}
